<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.controllers.Review.ReviewListController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="460.0" prefWidth="560.0" spacing="15.0">
         <children>
            <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Reviews" />
            <Label fx:id="avgRatingLabel" style="-fx-font-size: 16px; -fx-text-fill: #FFD700;" text="No reviews yet" />
            <ScrollPane prefHeight="380.0" prefWidth="560.0">
               <content>
                  <VBox fx:id="reviewsContainer" spacing="10.0" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
