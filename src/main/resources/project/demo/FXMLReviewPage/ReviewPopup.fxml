<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="350.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.controllers.Review.ReviewPopupController">
   <children>
      <VBox alignment="CENTER" layoutX="20.0" layoutY="20.0" prefHeight="310.0" prefWidth="460.0" spacing="15.0">
         <children>
            <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Review" />

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Button onAction="#setRating1" prefHeight="30.0" prefWidth="40.0" style="-fx-background-color: #FFD700;" text="1" />
                  <Button onAction="#setRating2" prefHeight="30.0" prefWidth="40.0" style="-fx-background-color: #FFD700;" text="2" />
                  <Button onAction="#setRating3" prefHeight="30.0" prefWidth="40.0" style="-fx-background-color: #FFD700;" text="3" />
                  <Button onAction="#setRating4" prefHeight="30.0" prefWidth="40.0" style="-fx-background-color: #FFD700;" text="4" />
                  <Button onAction="#setRating5" prefHeight="30.0" prefWidth="40.0" style="-fx-background-color: #FFD700;" text="5" />
               </children>
            </HBox>

            <Label style="-fx-text-fill: #666666; -fx-font-size: 12px;" text="Click a number to rate (5 = best)" />

            <TextArea fx:id="reviewTextArea" prefHeight="120.0" prefWidth="440.0" promptText="Write your review here..." wrapText="true" />

            <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" text="Error" visible="false" />

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button onAction="#handleSubmitReview" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 10;" text="Submit Review" />
                  <Button onAction="#handleCancel" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #999999; -fx-text-fill: white; -fx-background-radius: 10;" text="Cancel" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
