<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="793.6" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.controllers.Profile.ChangePasswordController">
   <children>
      <VBox alignment="CENTER_LEFT" layoutX="140.0" layoutY="80.0" prefHeight="300.0" prefWidth="513.0" spacing="15.0">
         <children>
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Current Password:" />
            <PasswordField fx:id="currentPasswordField" prefHeight="40.0" prefWidth="400.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="New Password:" />
            <PasswordField fx:id="newPasswordField" prefHeight="40.0" prefWidth="400.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Confirm New Password:" />
            <PasswordField fx:id="confirmPasswordField" prefHeight="40.0" prefWidth="400.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <Label fx:id="warningLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" text="Warning message" visible="false" />
            <Label fx:id="successLabel" style="-fx-text-fill: green; -fx-font-size: 12px;" text="Password changed successfully!" visible="false" />

            <HBox alignment="CENTER_RIGHT" prefWidth="400.0">
               <children>
                  <Button onAction="#handleChangePassword" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 10;" text="Change Password" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Label layoutX="103.0" layoutY="19.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Change Password" />
      <Label layoutX="103.0" layoutY="62.0" style="-fx-text-fill: #666666; -fx-font-size: 14px;" text="Update your account password here." />
   </children>
</AnchorPane>
