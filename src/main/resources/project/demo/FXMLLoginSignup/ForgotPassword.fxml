<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.demo.controllers.LoginSignup.ForgotPasswordController">
   <children>
      <VBox alignment="CENTER" layoutX="50.0" layoutY="50.0" prefHeight="400.0" prefWidth="500.0" spacing="20.0">
         <children>
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Reset Password">
               <font>
                  <Font size="28.0" />
               </font>
            </Label>
            <Label style="-fx-font-size: 14px; -fx-text-fill: #666666;" text="Enter your registered email to reset your password." />

            <TextField fx:id="emailField" prefHeight="45.0" prefWidth="400.0" promptText="Email address" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <Button onAction="#handleVerifyEmail" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #4A90D9; -fx-text-fill: white; -fx-background-radius: 10;" text="Verify Email" />

            <PasswordField fx:id="newPasswordField" disable="true" prefHeight="45.0" prefWidth="400.0" promptText="New password" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <PasswordField fx:id="confirmPasswordField" disable="true" prefHeight="45.0" prefWidth="400.0" promptText="Confirm new password" style="-fx-background-radius: 10; -fx-border-radius: 10;" />

            <Label fx:id="warningLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" text="Warning" visible="false" />
            <Label fx:id="successLabel" style="-fx-text-fill: green; -fx-font-size: 12px;" text="Success" visible="false" />

            <Button onAction="#handleResetPassword" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 10;" text="Reset Password" />

            <Button onAction="#handleBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: #4A90D9; -fx-underline: true;" text="Back to Login" />
         </children>
      </VBox>
   </children>
</AnchorPane>
